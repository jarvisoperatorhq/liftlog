{
  "expo": {
    "name": "LiftLog",
    "slug": "liftlog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0F1113",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1113"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jarvisoperatorhq.liftlog",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.jarvisoperatorhq.liftlog",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0F1113",
        "foregroundImage": "./assets/icon.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_PROJECT_ID"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/YOUR_PROJECT_ID",
      "checkAutomatically": "ON_LOAD"
    }
  }
}
